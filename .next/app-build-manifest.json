{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/page.js"
    ],
    "/(auth)/login/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(auth)/login/page.js"
    ],
    "/api/auth/[...all]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/auth/[...all]/route.js"
    ],
    "/(dashboard)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/layout.js"
    ],
    "/(dashboard)/dashboard/error": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/dashboard/error.js"
    ],
    "/(dashboard)/dashboard/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/dashboard/loading.js"
    ],
    "/(dashboard)/dashboard/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/dashboard/page.js"
    ],
    "/api/notifications/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/notifications/route.js"
    ],
    "/(dashboard)/quiz/error": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/quiz/error.js"
    ],
    "/(dashboard)/quiz/loading": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/quiz/loading.js"
    ],
    "/(dashboard)/quiz/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/quiz/page.js"
    ],
    "/api/quiz/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/quiz/route.js"
    ]
  }
}